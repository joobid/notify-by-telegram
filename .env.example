# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID
# To find it: send a message to your bot, then visit
# https://api.telegram.org/bot<your_token>/getUpdates
# and look for "chat":{"id": <your_chat_id>}
TELEGRAM_CHAT_ID=your_chat_id_here

# (Optional) Topic / Thread ID for groups with topics enabled
# To find it: right-click a message in the topic > "Copy Message Link"
# The URL looks like https://t.me/c/CHAT_ID/TOPIC_ID/MSG_ID
# Use the TOPIC_ID number.
# Can also be overridden per message with --topic
TELEGRAM_TOPIC_ID=
